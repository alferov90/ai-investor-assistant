# Copy to .deploy.env and fill in (file is gitignored).
DEPLOY_HOST=your.server.ip
DEPLOY_USER=dev
# Absolute path on VPS — do NOT use ~/ (expands to Mac home when sourced)
DEPLOY_PATH=/home/dev/ai-investor-assistant
DEPLOY_BRANCH=main
